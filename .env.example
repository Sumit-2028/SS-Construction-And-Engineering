# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info

# Neon PostgreSQL - required for login, admin dashboard, leads, and forms
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Auth.js - required. Generate with: npx auth secret
AUTH_SECRET="replace-with-at-least-32-random-characters"
AUTH_URL=http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Resend
RESEND_API_KEY=""
EMAIL_FROM="Construction Platform <noreply@example.com>"
