# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info

# Database (replace with your provider connection string)
# Example (Postgres local): postgresql://user:pass@localhost:5432/dbname?schema=public
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?schema=public
DIRECT_URL=postgresql://<user>:<password>@<host>:5432/<db>

# Auth (required) — generate a secure 32+ char secret
# Recommended: `npx auth secret` or:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional - leave empty to disable/send-noop)
RESEND_API_KEY=
EMAIL_FROM=Your Company <noreply@example.com>

# Due reminders (optional)
REMINDER_CRON_SECRET=

# Notes:
# - Copy this file to `.env.local` and fill in real values. Do NOT commit `.env.local` to git.
# - When deploying (Vercel, etc.) set equivalent environment variables in the platform dashboard.
